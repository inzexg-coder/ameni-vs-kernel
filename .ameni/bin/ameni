#!/usr/bin/env bash
set -euo pipefail

readonly AMENI_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly AMENI_REPO_URL="https://github.com/inzexg-coder/ameni-vs-kernel"
readonly AMENI_SCRIPTS="$(cd "$(dirname "$AMENI_HOME")" && pwd)/scripts"

readonly CLR_RESET='\033[0m'
readonly CLR_RED='\033[0;31m'
readonly CLR_GREEN='\033[0;32m'
readonly CLR_YELLOW='\033[1;33m'
readonly CLR_CYAN='\033[0;36m'
readonly CLR_BOLD='\033[1m'
readonly CLR_DIM='\033[2m'

_info()   { echo -e "${CLR_GREEN}[INFO]${CLR_RESET}  $*"; }
_warn()   { echo -e "${CLR_YELLOW}[WARN]${CLR_RESET}  $*"; }
_error()  { echo -e "${CLR_RED}[ERROR]${CLR_RESET} $*" >&2; }
_header() { echo -e "${CLR_CYAN}=== $* ===${CLR_RESET}"; }

_is_windows() {
  case "$(uname -s)" in
    CYGWIN*|MINGW*|MSYS*) return 0 ;;
    *) return 1 ;;
  esac
}

_is_linux() {
  [ "$(uname -s)" = "Linux" ]
}

_cmd_diagnose() {
  _header "Environment Diagnostics"
  echo "OS: $(uname -s) ($(uname -m))"
  echo ""

  if _is_windows; then
    if command -v pwsh &>/dev/null; then
      pwsh -NoProfile -ExecutionPolicy Bypass -File "$AMENI_SCRIPTS/verify-environment.ps1"
    else
      _info "Native diagnostics (Git Bash / WSL)"
      for cmd in dotnet pwsh node; do
        if command -v "$cmd" &>/dev/null; then
          _info "${cmd}: $("$cmd" --version 2>/dev/null | head -1)"
        else
          _warn "${cmd} not found in PATH"
        fi
      done
      _info ""
      _warn "Full VS diagnostics require PowerShell Core."
      _warn "  Install: pwsh -Command \"& { Install-Module -Name PowerShellGet -Force }\""
      _info ""
      _info "Or run the PowerShell script directly:"
      _info "  pwsh ./scripts/verify-environment.ps1"
    fi
  elif _is_linux; then
    _info "dotnet: $(dotnet --version 2>/dev/null || echo 'not found')"
    _info "mono: $(mono --version 2>/dev/null | head -1 || echo 'not found')"
    _info "pwsh: $(pwsh --version 2>/dev/null || echo 'not found')"
    _info "node: $(node --version 2>/dev/null || echo 'not found')"
    echo ""

    _header "Build Tools"
    for tool in gcc g++ make cmake clang lldb; do
      if command -v "$tool" &>/dev/null; then
        _info "${tool}: $("$tool" --version 2>/dev/null | head -1)"
      fi
    done

    echo ""
    _header "Recommended"
    if command -v dotnet &>/dev/null; then _info ".NET SDK is ready. Use 'dotnet build' for C++/CLI projects."; fi
    if command -v pwsh &>/dev/null; then _info "PowerShell Core is ready. Run 'pwsh ./scripts/verify-environment.ps1'."; fi
    _info "Reference configuration: see props/*.props and vs20*/ directories."
  else
    _info "macOS detected. Use 'brew install dotnet-sdk mono powershell'."
  fi
}

_cmd_check() {
  local path="${1:-.}"

  if [ ! -d "$path" ]; then
    _error "Directory not found: $path"
    exit 1
  fi

  _header "Project Structure Check"
  path="$(cd "$path" && pwd 2>/dev/null || echo "$path")"
  echo "Path: ${path}"
  echo ""

  local vcxproj_files
  if _is_windows; then
    vcxproj_files=$(find "$path" -name "*.vcxproj" -type f 2>nul | head -10 || true)
  else
    vcxproj_files=$(find "$path" -name "*.vcxproj" -type f 2>/dev/null | head -10 || true)
  fi

  if [ -n "$vcxproj_files" ]; then
    _info "Found .vcxproj files:"
    echo "$vcxproj_files" | while IFS= read -r f; do
      echo "    $(basename "$f")"
    done

    local issues=0
    echo "$vcxproj_files" | while IFS= read -r proj; do
      local ld
      ld=$(grep -oE '<LibraryDirectories>[^<]*</LibraryDirectories>' "$proj" 2>/dev/null || echo "")
      if [ -n "$ld" ] && ! echo "$ld" | grep -q 'VC_LibraryPath'; then
        _warn "  $(basename "$proj"): LibraryDirectories non-standard: ${ld}"
        issues=$((issues + 1))
      fi
    done
    echo ""
    _info "Check complete."
  else
    _warn "No .vcxproj files found in ${path}"
    _info "This is expected if this is not a Visual Studio project directory."
  fi
}

_cmd_props() {
  _header "Available Property Sheets"
  echo ""
  local props_dir="$AMENI_HOME/../props"
  if [ -d "$props_dir" ]; then
    for f in "$props_dir"/*.props; do
      if [ -f "$f" ]; then
        local name
        name=$(basename "$f" .props)
        local desc
        desc=$(head -1 "$f" 2>/dev/null | grep -oE '<\w+>.*</\w+>' | sed 's/<[^>]*>//g' || echo "")
        printf "  %-30s %s\n" "$name" "${desc:-no description}"
      fi
    done
  else
    _warn "props/ directory not found"
  fi
  echo ""
  _info "Usage: Add props via Visual Studio Property Manager or edit .vcxproj directly."
  _info "Reference: see vs2017/, vs2022/, vs2025/ for toolset-specific configs."
}

_cmd_errors() {
  local error="${1:-}"
  _header "Linker Error Reference"
  echo ""

  if [ -n "$error" ]; then
    local file="$AMENI_HOME/../errors/${error}.md"
    if [ -f "$file" ]; then
      cat "$file"
    else
      _error "Error reference not found: ${error}"
      _info "Available references:"
      for f in "$AMENI_HOME"/../errors/*.md; do
        if [ -f "$f" ]; then
          echo "  - $(basename "$f" .md)"
        fi
      done
    fi
  else
    _info "Available error references:"
    for f in "$AMENI_HOME"/../errors/*.md; do
      if [ -f "$f" ]; then
        local name
        name=$(basename "$f" .md)
        local desc
        desc=$(head -1 "$f" 2>/dev/null | sed 's/# //' || echo "")
        printf "  %-35s %s\n" "$name" "${desc:-}"
      fi
    done
    echo ""
    _info "Usage: ameni vs errors <error-name>"
    _info "Example: ameni vs errors lnk1104-cannot-open-file"
  fi
}

_cmd_about() {
  echo ""
  echo "Ameni VS Kernel"
  echo "Visual Studio Configuration Archive & Diagnostic Agent"
  echo "${AMENI_REPO_URL}"
  echo ""
  echo "Platforms: Arch Linux (bash) / Windows (Git Bash, WSL, pwsh)"
  echo ""
  echo "Commands:"
  echo "  diagnose         Full environment diagnostics"
  echo "  check [path]     Inspect .vcxproj files"
  echo "  props            List available property sheets"
  echo "  errors [name]    Linker error reference"
  echo "  about            Display this information"
  echo "  help             Show detailed usage"
  echo ""
}

_cmd_help() {
  echo ""
  echo -e "${CLR_BOLD}NAME${CLR_RESET}"
  echo "  ameni vs - Visual Studio build diagnostic agent (cross-platform)"
  echo ""
  echo -e "${CLR_BOLD}SYNOPSIS${CLR_RESET}"
  echo "  ameni vs diagnose"
  echo "  ameni vs check [path]"
  echo "  ameni vs props"
  echo "  ameni vs errors [name]"
  echo "  ameni vs about"
  echo "  ameni vs help"
  echo ""
  echo -e "${CLR_BOLD}COMMANDS${CLR_RESET}"
  echo ""
  echo -e "  ${CLR_GREEN}diagnose${CLR_RESET}"
  echo "    Cross-platform environment check."
  echo "    Windows: detects VS, SDK, MSVC via verify-environment.ps1"
  echo "    Linux:   detects dotnet, mono, pwsh, build-essential tools"
  echo "    Example: ameni vs diagnose"
  echo ""
  echo -e "  ${CLR_GREEN}check [path]${CLR_RESET}"
  echo "    Inspect .vcxproj files for non-standard LibraryDirectories."
  echo "    Default path: current directory."
  echo "    Example: ameni vs check ./MyProject"
  echo ""
  echo -e "  ${CLR_GREEN}props${CLR_RESET}"
  echo "    List available property sheets in props/ directory."
  echo "    Example: ameni vs props"
  echo ""
  echo -e "  ${CLR_GREEN}errors [name]${CLR_RESET}"
  echo "    Display linker error reference from errors/ directory."
  echo "    Without argument, lists all available references."
  echo "    Example: ameni vs errors lnk1104-cannot-open-file"
  echo ""
  echo -e "${CLR_BOLD}CROSS-PLATFORM NOTES${CLR_RESET}"
  echo "  Arch Linux:"
  echo "    pacman -S dotnet-sdk powershell"
  echo "    pwsh ./scripts/verify-environment.ps1"
  echo ""
  echo "  Windows (Git Bash / WSL):"
  echo "    Run from 'Git Bash' or 'WSL' terminal."
  echo "    pwsh ./scripts/verify-environment.ps1"
  echo ""
  echo -e "${CLR_BOLD}FILES${CLR_RESET}"
  echo "  Directory        Content"
  echo "  scripts/         PowerShell diagnostic scripts"
  echo "  props/           Reference property sheets (.props)"
  echo "  errors/          Linker error documentation"
  echo "  vs2017..2025/    Per-version configuration guides"
  echo "  .vsconfig        VS Installer manifest"
  echo ""
  echo -e "${CLR_BOLD}REFERENCE${CLR_RESET}"
  echo "  ${AMENI_REPO_URL}"
  echo ""
}

# --- Main ---
command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  diagnose)  _cmd_diagnose "$@" ;;
  check)     _cmd_check "$@" ;;
  props)     _cmd_props "$@" ;;
  errors)    _cmd_errors "$@" ;;
  about)     _cmd_about ;;
  help|--help|-h|*) _cmd_help ;;
esac
